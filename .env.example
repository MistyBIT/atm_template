# PostgreSQL (та же БД, что у ATM)
DATABASE_URL=postgres://user:pass@127.0.0.1:5432/atm_db

# Идентификация строки tools.tools (задайте одно из двух)
ATM_TOOL_ID=1
# ATM_TOOL_NAME=my_tool

# Публикация портов на хосте (docker compose)
TOOL_API_PUBLISH_PORT=8091
TOOL_MF_PUBLISH_PORT=8092

# Имя MF remote при сборке образа (как config.ui.remoteKey в БД)
# ATM_TEMPLATE_REMOTE_NAME=remote_my_tool
